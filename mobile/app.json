{
  "expo": {
    "name": "Mac Septic Field",
    "slug": "mac-septic-field",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "macseptic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a365d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.macseptic.field",
      "infoPlist": {
        "NSCameraUsageDescription": "Mac Septic Field uses the camera to capture before and after photos of work sites for documentation.",
        "NSLocationWhenInUseUsageDescription": "Mac Septic Field uses your location to verify arrival at job sites and optimize routing.",
        "NSPhotoLibraryUsageDescription": "Mac Septic Field accesses your photo library to attach existing photos to work orders.",
        "CFBundleDisplayName": "Mac Septic",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a365d"
      },
      "package": "com.macseptic.field",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Mac Septic Field to access your camera to capture work site photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Mac Septic Field to access your photos for work order documentation.",
          "cameraPermission": "Allow Mac Septic Field to take photos for work order documentation."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Mac Septic Field to use your location to verify arrival at work sites and optimize routing."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a365d"
        }
      ],
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Allow Mac Septic Field to access your camera to scan equipment barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://react-crm-api-production.up.railway.app/api/v2",
      "eas": {
        "projectId": "5946c232-1c4b-4016-8218-d7780771eaf9"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "rondiggity1",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/5946c232-1c4b-4016-8218-d7780771eaf9"
    }
  }
}
